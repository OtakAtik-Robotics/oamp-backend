# Database (PostgreSQL)
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=oamp
DB_PORT=5432

# Server
PORT=8080

# CORS - Allowed origins (comma-separated) or "*" for all origins
CORS_ORIGINS=*

# AI Provider (openai, gemini, claude, minimax)
AI_PROVIDER=minimax
AI_API_KEY=your_api_key_here
AI_MODEL=MiniMax-M2.7
AI_BASE_URL=
MINIMAX_GROUP_ID=your_group_id_here
